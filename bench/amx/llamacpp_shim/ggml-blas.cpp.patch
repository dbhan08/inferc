+#if defined(GGML_BLAS_USE_ACCELERATE) && defined(__aarch64__)
+            // ours: constant-weight (leaf src0) fp32 matmul -> pre-packed AMX.
+            // x = src0[N=ne01, K=ne00] weight; y = src1[M=ne1, K=ne10] acts;
